{
	"expo": {
		"name": "CanchApp",
		"slug": "CanchApp",
		"owner": "shamanking22",
		"version": "1.0.0",
		"orientation": "portrait",
		"icon": "./assets/images/Logo/1024.png",
		"scheme": "canchapp",
		"userInterfaceStyle": "automatic",
		"newArchEnabled": true,
		"ios": {
			"icon": "./assets/images/Logo/appstore.png",
			"bundleIdentifier": "com.romani22.canchapp",
			"supportsTablet": true,
			"infoPlist": {
				"NSPhotoLibraryUsageDescription": "CanchApp necesita acceso a tu galería para que puedas elegir una foto de perfil.",
				"NSCameraUsageDescription": "CanchApp necesita acceso a tu cámara para sacar una foto de perfil.",
				"NSLocationWhenInUseUsageDescription": "CanchApp usa tu ubicación para mostrarte canchas y partidos cercanos a vos.",
				"NSLocationAlwaysAndWhenInUseUsageDescription": "CanchApp usa tu ubicación para mostrarte canchas y partidos cercanos a vos.",
				"NSFaceIDUsageDescription": "CanchApp usa Face ID para que puedas iniciar sesión rápidamente."
			}
		},
		"android": {
			"package": "com.romani22.canchapp",
			"adaptiveIcon": {
				"foregroundImage": "./assets/images/Logo/playstore.png",
				"backgroundColor": "#ffffff"
			},
			"googleServicesFile": "./google-services.json",
			"edgeToEdgeEnabled": true,
			"predictiveBackGestureEnabled": false,
			"permissions": ["android.permission.READ_MEDIA_IMAGES", "android.permission.READ_EXTERNAL_STORAGE", "android.permission.ACCESS_COARSE_LOCATION", "android.permission.ACCESS_FINE_LOCATION", "android.permission.POST_NOTIFICATIONS", "android.permission.RECEIVE_BOOT_COMPLETED", "android.permission.VIBRATE", "android.permission.SCHEDULE_EXACT_ALARM", "android.permission.USE_EXACT_ALARM"]
		},
		"web": {
			"output": "static",
			"favicon": "./assets/images/Logo/1024.png"
		},
		"plugins": [
			"expo-router",
			[
				"expo-splash-screen",
				{
					"image": "./assets/images/Logo/1024.png",
					"imageWidth": 200,
					"resizeMode": "contain",
					"backgroundColor": "#ffffff",
					"dark": {
						"backgroundColor": "#000000"
					}
				}
			],
			"@react-native-community/datetimepicker",
			[
				"expo-notifications",
				{
					"icon": "./assets/images/Logo/1024.png",
					"color": "#ffffff",
					"androidMode": "default",
					"androidCollapsedTitle": "#{unread_notifications} notificaciones",
					"iosDisplayInForeground": true
				}
			],
			"expo-secure-store",
			"expo-web-browser",
			[
				"expo-image-picker",
				{
					"photosPermission": "CanchApp necesita acceso a tu galería para que puedas elegir una foto de perfil.",
					"cameraPermission": "CanchApp necesita acceso a tu cámara para sacar una foto de perfil."
				}
			],
			[
				"expo-location",
				{
					"locationWhenInUsePermission": "CanchApp usa tu ubicación para mostrarte canchas y partidos cercanos a vos."
				}
			]
		],
		"experiments": {
			"typedRoutes": true,
			"reactCompiler": true
		},
		"extra": {
			"router": {},
			"eas": {
				"projectId": "b998229a-6c03-4982-a66a-b8b112ed0318"
			}
		}
	}
}
